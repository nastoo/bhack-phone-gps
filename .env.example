# Traefik hostname — must match DNS A/AAAA record AND the URL in your browser
TRAEFIK_HOST=gps.moln.nasto.ovh

# Must match certificatesResolvers.<name> in your Traefik static config (often letsencrypt or le)
CERT_RESOLVER=letsencrypt

# Optional shared secret (phone sends X-GPS-Token header)
# GPS_TOKEN=demo-secret

GPS_HISTORY_SIZE=120
